# Maintainer: EaeDave <202521901+EaeDave at users dot noreply dot github dot com>

pkgname=ytui-dl-git
pkgver=0.1.0.r0.g8fb340e
pkgrel=1
pkgdesc="YouTube TUI downloader powered by yt-dlp"
arch=('x86_64')
url="https://github.com/EaeDave/ytui-dl"
license=('MIT')
depends=('gcc-libs' 'yt-dlp')
optdepends=('ffmpeg: merge video/audio streams and convert audio formats')
makedepends=('cargo' 'git')
provides=('ytd')
conflicts=('ytd' 'ytui-dl')
options=('!lto')
source=("$pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd "$pkgname"
  local tag
  tag=$(git describe --tags --abbrev=0 2>/dev/null || true)
  if [[ -n $tag ]]; then
    # e.g. v0.1.0-3-gabcdef1 → 0.1.0.r3.gabcdef1
    git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
  else
    printf "0.1.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
  fi
}

prepare() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --frozen --release --all-features
}

check() {
  cd "$pkgname"
  export RUSTUP_TOOLCHAIN=stable
  cargo test --frozen --release
}

package() {
  cd "$pkgname"
  install -Dm755 "target/release/ytd" "$pkgdir/usr/bin/ytd"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
